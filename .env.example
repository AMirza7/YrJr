# YrJr Legal Assistant - Environment Configuration

# API Configuration
API_BASE_URL=https://api.yrjr.app/v1
API_TIMEOUT=30000

# Authentication
JWT_SECRET_KEY=your-jwt-secret-key-here
REFRESH_TOKEN_EXPIRY=7d
ACCESS_TOKEN_EXPIRY=1h

# Feature Flags
ENABLE_AI_ASSISTANT=true
ENABLE_BIOMETRIC_AUTH=true
ENABLE_VOICE_SEARCH=true
ENABLE_DOCUMENT_SCANNER=true
ENABLE_PUSH_NOTIFICATIONS=true
ENABLE_OFFLINE_MODE=false
ENABLE_ANALYTICS=true
ENABLE_DEBUG_MODE=false

# Language & Localization
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,hi,bn,ta,te,mr,gu,kn,ml,pa,ur,or,as
RTL_LANGUAGES=ur,ar

# External Services
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_MESSAGING_SENDER_ID=your-firebase-sender-id

# AI & ML Services
OPENAI_API_KEY=your-openai-api-key
GOOGLE_TRANSLATE_API_KEY=your-google-translate-key
OCR_SERVICE_URL=https://ocr.yrjr.app/v1

# Analytics & Monitoring
SENTRY_DSN=your-sentry-dsn
MIXPANEL_TOKEN=your-mixpanel-token
GOOGLE_ANALYTICS_ID=your-ga-id

# Payment Gateway
RAZORPAY_KEY_ID=your-razorpay-key
STRIPE_PUBLISHABLE_KEY=your-stripe-key

# Maps & Location
GOOGLE_MAPS_API_KEY=your-google-maps-key

# Content Delivery
CDN_BASE_URL=https://cdn.yrjr.app
ASSETS_BASE_URL=https://assets.yrjr.app

# Development & Testing
MOCK_API_DELAY=1000
ENABLE_API_MOCKS=true
LOG_LEVEL=debug
ENABLE_FLIPPER=false

# Security
ENCRYPTION_KEY=your-encryption-key-here
API_RATE_LIMIT=100
MAX_FILE_UPLOAD_SIZE=10MB

# Regional Settings
DEFAULT_TIMEZONE=Asia/Kolkata
DEFAULT_CURRENCY=INR
DEFAULT_COUNTRY=IN
