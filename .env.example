# YrJr Legal Assistant - Environment Configuration
# Copy this file to .env and fill in your actual values

# ==================== API CONFIGURATION ====================
# Base URL for your backend API
API_BASE_URL=https://api.yrjr.app/v1
# API timeout in milliseconds
API_TIMEOUT=30000

# ==================== FEATURE FLAGS ====================
# Enable/disable major app features
ENABLE_AI_ASSISTANT=true
ENABLE_BIOMETRIC_AUTH=true
ENABLE_VOICE_SEARCH=true
ENABLE_DOCUMENT_SCANNER=true
ENABLE_PUSH_NOTIFICATIONS=true
ENABLE_OFFLINE_MODE=false
ENABLE_ANALYTICS=true
ENABLE_DEBUG_MODE=false

# ==================== LANGUAGE & LOCALIZATION ====================
# Default language for the app
DEFAULT_LANGUAGE=en
# Comma-separated list of supported languages
SUPPORTED_LANGUAGES=en,hi,bn,ta,te,mr,gu,kn,ml,pa,ur,or,as
# Right-to-left languages
RTL_LANGUAGES=ur,ar

# ==================== FIREBASE CONFIGURATION ====================
# Firebase project configuration
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_MEASUREMENT_ID=your_measurement_id

# ==================== AI & ML SERVICES ====================
# OpenAI API for AI Assistant
OPENAI_API_KEY=your_openai_api_key
# Google Translate API for multi-language support
GOOGLE_TRANSLATE_API_KEY=your_google_translate_key
# OCR service for document scanning
OCR_SERVICE_URL=https://ocr.yrjr.app/v1

# ==================== ANALYTICS & MONITORING ====================
# Error tracking and monitoring
SENTRY_DSN=your_sentry_dsn_here
# User analytics
MIXPANEL_TOKEN=your_mixpanel_token
# Google Analytics
GOOGLE_ANALYTICS_ID=your_ga_id

# ==================== PAYMENT GATEWAYS ====================
# Razorpay for Indian market
RAZORPAY_KEY_ID=your_razorpay_key
RAZORPAY_KEY_SECRET=your_razorpay_secret
# Stripe for international payments
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_SECRET_KEY=your_stripe_secret_key

# ==================== MAPS & LOCATION ====================
# Google Maps for location services
GOOGLE_MAPS_API_KEY=your_google_maps_key

# ==================== CONTENT DELIVERY ====================
# CDN for static assets
CDN_BASE_URL=https://cdn.yrjr.app
# Assets base URL
ASSETS_BASE_URL=https://assets.yrjr.app

# ==================== DEVELOPMENT & TESTING ====================
# Mock API delay in milliseconds (development only)
MOCK_API_DELAY=1000
# Enable API mocks for development
ENABLE_API_MOCKS=true
# Log level (debug, info, warn, error)
LOG_LEVEL=debug

# ==================== SECURITY ====================
# Encryption key for sensitive data (MUST be changed in production)
ENCRYPTION_KEY=your_super_secure_encryption_key_here
# API rate limiting (requests per minute)
API_RATE_LIMIT=100
# Maximum file upload size
MAX_FILE_UPLOAD_SIZE=10MB

# ==================== REGIONAL SETTINGS ====================
# Default timezone
DEFAULT_TIMEZONE=Asia/Kolkata
# Default currency
DEFAULT_CURRENCY=INR
# Default country
DEFAULT_COUNTRY=IN

# ==================== THIRD-PARTY INTEGRATIONS ====================
# Social login providers
GOOGLE_CLIENT_ID=your_google_client_id
FACEBOOK_APP_ID=your_facebook_app_id

# ==================== COMMUNICATION SERVICES ====================
# SMS service for OTP
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=your_twilio_phone

# Email service
SENDGRID_API_KEY=your_sendgrid_key
FROM_EMAIL=noreply@yrjr.app

# ==================== CLOUD STORAGE ====================
# AWS S3 for file storage
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=yrjr-documents

# ==================== PUSH NOTIFICATIONS ====================
# OneSignal for push notifications
ONESIGNAL_APP_ID=your_onesignal_app_id
ONESIGNAL_REST_API_KEY=your_onesignal_rest_key

# ==================== LEGAL APIS ====================
# Indian Court API integrations
ECOURTS_API_KEY=your_ecourts_api_key
CASE_STATUS_API_URL=https://services.ecourts.gov.in/ecourtindia_v6
CAUSE_LIST_API_URL=https://api.ecourts.gov.in/causelist

# ==================== DEPLOYMENT ====================
# Environment type
NODE_ENV=development
# Version info
APP_VERSION=1.0.0
BUILD_NUMBER=1
